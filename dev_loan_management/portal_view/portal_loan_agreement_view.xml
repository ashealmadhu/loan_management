    <template id="portal_my_home_loan_agreement" name="Portal My Agreement: Agreement Details" customize_show="True" inherit_id="portal.portal_my_home" priority="20">
    	<xpath expr="//div[hasclass('o_portal_docs')]" position="before">
    	<t t-set="portal_client_category_enable" t-value="True"/>
    	<!-- <t t-set="portal_alert_category_enable" t-value="True"/> -->
    	</xpath>
    	<div id="portal_client_category" position="inside">
    	<t t-call="portal.portal_docs_entry">
        	<t t-set="placeholder_count" t-value="'agreement_count'"/>
        	<t t-set="icon" t-value="'/dev_loan_management/static/description/images/bag.svg'" />
        	<t t-set="title">Loan Agreement</t>
        	<t t-set="url" t-value="'/my/agreement_details'"/>
        	<t t-set="text">Follow, view or print your agreements</t>
        	<!-- <t t-set="show_count" t-value="True"/> -->
       	 
    	</t>
    	</div>
 	</template>

    <template id="portal_my_home_menu_agreement_details" name="Portal Layout : Agreement Details Menu"
        inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'agreement_details_tree'"
                t-attf-class="breadcrumb-item #{'active' if not agreement_detail else ''}">
                Agreement Details
            </li>
            <li t-if="page_name == 'agreement_detail_page'" class="breadcrumb-item active">
                <a t-if="agreement_detail" t-attf-href="/my/agreement_details?{{ keep_query() }}">Agreement Details</a>
                / Agreement-<t t-esc="agreement_detail.name" />
            </li>
        </xpath>
    </template>

    <template id="portal_my_agreement_details" name="My Agreement Details">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Agreement Details</t>
            </t>
            <t t-if="not agreement_details">
                <p>There are currently no Agreement for your account.</p>
            </t>
            <t t-if="agreement_details" t-call="portal.portal_table">
                <t t-foreach="grouped_agreements" t-as="group_agreement">
                    <thead>
                        <tr t-attf-class="{{'thead-light' if not groupby == 'none' else ''}}">
                            <th t-if="groupby == 'none'">Number #</th>
                            <th t-else="">
                                <t t-if="groupby == 'loan_id'">
                                    <em class="font-weight-normal text-muted">Loan:</em>
                                    <span t-esc="group_agreement[0].sudo().loan_id.name"/>
                                </t>
                                <t t-if="groupby == 'agreement_type_id'">
                                    <em class="font-weight-normal text-muted">Agreement Type:</em>
                                    <span t-esc="group_agreement[0].sudo().agreement_type_id.name"/>
                                </t>
                            </th>
                            <th>Loan</th>
                            <th>Client</th>
                            <th>Agreement Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="group_agreement" t-as="l">
                            <tr>
                                <td>
                                    <a t-att-href="l.get_portal_url()">
                                        <t t-esc="l.name" />
                                    </a>
                                </td>
                                <td>
                                    <span t-field="l.loan_id" />
                                </td>
                                <td>
                                    <span t-field="l.partner_id" />
                                </td>
                                <td>
                                    <span t-field="l.agreement_type_id" />
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </t>
    </template>


    <template id="portal_my_agreement_detail_form" name="Agreement Detail Portal Template"
        inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row mt16 o_portal_sale_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-auto d-print-none'" />
                    <t t-set="title">
                        <h2 class="mb-0">
                            <span t-field="agreement_detail.name" />
                        </h2>
                    </t>
                    <t t-set="entries">
                        <ul class="list-group list-group-flush flex-wrap flex-row flex-lg-column">
                            <li class="list-group-item flex-grow-1">
                                <div class="o_download_pdf btn-toolbar flex-sm-nowrap">
                                    <div class="btn-group flex-grow-1 mr-1 mb-1">
                                        <a class="btn btn-secondary btn-block o_download_btn" t-att-href="agreement_detail.get_portal_url(report_type='pdf', download=True)" title="Download"><i class="fa fa-download"/> Download</a>
                                    </div>
                                    <div class="btn-group flex-grow-1 mb-1" style="margin-left:15px;">
                                        <a class="btn btn-secondary btn-block o_print_btn o_portal_invoice_print" t-att-href="agreement_detail.get_portal_url(report_type='pdf')" id="print_loan_agreement_report" title="Print" target="_blank"><i class="fa fa-print"/> Print</a>
                                    </div>
                                </div>
                            </li>
                            <li class="navspy list-group-item pl-0 flex-grow-1" t-ignore="true"
                                role="complementary">
                                <ul class="nav flex-column bs-sidenav"></ul>
                            </li>

                            <li t-if="agreement_detail.partner_id" class="list-group-item flex-grow-1">
                                <div t-if="agreement_detail.partner_id">
                                    <h6><small class="text-muted">Your contact</small></h6>
                                    <div class="o_portal_contact_details d-flex flex-column gap-2">
                                        <div class="d-flex justify-content-start align-items-center gap-2">
                                            <img class="o_avatar o_portal_contact_img rounded" t-att-src="image_data_uri(agreement_detail.partner_id.avatar_1024)" alt="Contact"/>
                                            <div>
                                                <h6 class="mb-0" t-out="agreement_detail.partner_id.name"/>
                                                <a href="#discussion" class="d-flex align-items-center gap-2 small fw-bold">
                                                Send message
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </t>
                </t>
                <div id="agreement_detail_content" class="col-12 col-lg justify-content-end">
                    <div t-attf-class="card #{'pb-5' if report_type == 'html' else ''}">
                        <div t-call="dev_loan_management.agreement_detail_portal_content" />
                    </div>
                    <div id="agreement_detail_communication" class="mt-3">
                        <h3>Communication history</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="agreement_detail" />
                        </t>
                    </div>
                </div>
                <hr />

            </div>
        </xpath>
    </template>

